# Akin — backend env
# Copy to .env and fill in.

API_PORT=8080
APP_ENV=development

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://akin:akin_dev@localhost:55432/akin?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Session
SESSION_COOKIE_NAME=akin_session
SESSION_TTL_HOURS=720
# Generate with: openssl rand -hex 32
SESSION_KEY=replace_me_with_32_byte_hex

# Paystack — get test keys from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me

# Public base URLs (used for Paystack callback redirect)
API_BASE_URL=http://localhost:8080
APP_BASE_URL=http://localhost:5173

# CORS allowed origin (frontend)
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Dev-only: bypass real Paystack Transfer (needed if Paystack account is a
# "starter business" that can't initiate third-party payouts yet). When true,
# /steward/payouts/:id/confirm marks the payout succeeded locally and writes
# a "payout_confirmed_mock" audit row instead of calling Paystack.
MOCK_TRANSFERS=false

# Email (SMTP). For Gmail, use an app password, not your normal account password.
EMAIL_FROM="Akin <yourgmail@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=replace_me_with_google_app_password

# Resend webhook signing secret — dormant while SMTP is used for sending.
RESEND_WEBHOOK_SECRET=
